     1                                  ; programa2.asm - Laboratorio Post2 Unidad 4
     2                                  ; Proposito: demostrar macros con parametros, bucles LOOP y condicionales CMP/Jcc
     3                                  
     4                                  %include "macros.asm"       ; incluir biblioteca de macros utilitarias
     1                              <1> ; macros.asm - biblioteca de macros utilitarias para NASM 16-bit DOS
     2                              <1> 
     3                              <1> ; Macro: terminar programa DOS con codigo de salida 0
     4                              <1> %macro fin_dos 0
     5                              <1>     mov ax, 4C00h
     6                              <1>     int 21h
     7                              <1> %endmacro
     8                              <1> 
     9                              <1> ; Macro: imprimir nueva linea (CR + LF)
    10                              <1> %macro nueva_linea 0
    11                              <1>     mov ah, 02h
    12                              <1>     mov dl, 0Dh
    13                              <1>     int 21h
    14                              <1>     mov ah, 02h
    15                              <1>     mov dl, 0Ah
    16                              <1>     int 21h
    17                              <1> %endmacro
    18                              <1> 
    19                              <1> ; Macro: imprimir cadena terminada en "$"
    20                              <1> ; %1 = etiqueta de la cadena
    21                              <1> %macro print_str 1
    22                              <1>     mov ah, 09h
    23                              <1>     mov dx, %1
    24                              <1>     int 21h
    25                              <1> %endmacro
    26                              <1> 
    27                              <1> ; Macro: imprimir un caracter unico
    28                              <1> ; %1 = valor ASCII del caracter (inmediato o registro)
    29                              <1> %macro print_char 1
    30                              <1>     mov ah, 02h
    31                              <1>     mov dl, %1
    32                              <1>     int 21h
    33                              <1> %endmacro
    34                              <1> 
    35                              <1> ; Macro: leer un caracter desde teclado (sin eco)
    36                              <1> ; Resultado queda en AL
    37                              <1> %macro leer_char 0
    38                              <1>     mov ah, 07h
    39                              <1>     int 21h
    40                              <1> %endmacro
    41                              <1> 
    42                              <1> ; Macro: imprimir una cadena N veces
    43                              <1> ; %1 = etiqueta de la cadena a imprimir
    44                              <1> ; %2 = numero de repeticiones (inmediato numerico)
    45                              <1> %macro repetir_str 2
    46                              <1>     mov cx, %2              ; CX = contador de repeticiones
    47                              <1> %%ciclo:                    ; %% genera etiqueta unica por expansion
    48                              <1>     mov ah, 09h
    49                              <1>     mov dx, %1
    50                              <1>     int 21h
    51                              <1>     loop short %%ciclo      ; CX--; si CX != 0, repetir
    52                              <1> %endmacro
    53                              <1> 
    54                              <1> ; Macro: imprimir digito decimal de un valor 0-9 almacenado en AL
    55                              <1> %macro print_digito 0
    56                              <1>     push ax                 ; preservar AX
    57                              <1>     and al, 0Fh             ; asegurar nibble bajo (0-9)
    58                              <1>     add al, 30h             ; convertir a ASCII: 0->"0", 9->"9"
    59                              <1>     mov ah, 02h
    60                              <1>     mov dl, al
    61                              <1>     int 21h
    62                              <1>     pop ax                  ; restaurar AX
    63                              <1> %endmacro
