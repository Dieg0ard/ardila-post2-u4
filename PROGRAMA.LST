    57 00000082 240F                <1>  and al, 0Fh
    58 00000084 0430                <1>  add al, 30h
    59 00000086 B402                <1>  mov ah, 02h
    60 00000088 88C2                <1>  mov dl, al
    61 0000008A CD21                <1>  int 21h
    62 0000008C 58                  <1>  pop ax
    91                                      nueva_linea
