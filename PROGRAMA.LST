    57                                  
    58                                  ; ────────────────────────────────────────────────────────────────────────
    59                                  ; Procedimiento: suma acumulativa 1+2+3+...+N
    60                                  ; Entrada:  CX = N
    61                                  ; Salida:   AX = suma total
    62                                  ; Modifica: AX (intencionalmente), preserva CX
    63                                  ; ────────────────────────────────────────────────────────────────────────
    64                                  sumar_serie:
    65 00000067 51                          push cx                 ; preservar CX (se modifica con LOOP)
    66 00000068 31C0                        xor ax, ax              ; AX = 0 (acumulador)
    67                                  .paso:
    68 0000006A 01C8                        add ax, cx              ; AX += CX (suma N, N-1, ..., 1)
    69 0000006C E2FC                        loop short .paso        ; CX--; si CX != 0, continuar
    70 0000006E 59                          pop cx                  ; restaurar CX original
    71 0000006F C3                          ret
    72                                  
    73                                  ; ────────────────────────────────────────────────────────────────────────
    74                                  ; Procedimiento: comparar AX y BX e imprimir el mayor
    75                                  ; Entrada:  AX = primer valor, BX = segundo valor (ambos 0-9)
    76                                  ; Salida:   ninguna (solo imprime en pantalla)
    77                                  ; Preserva: AX, BX
    78                                  ; ────────────────────────────────────────────────────────────────────────
    79                                  comparar_e_imprimir:
    80 00000070 50                          push ax
    81 00000071 53                          push bx
    82                                  
    83 00000072 39D8                        cmp ax, bx
    84 00000074 7444                        je  .son_iguales
    85 00000076 7F23                        jg  .ax_mayor
    86                                  
    87                                      ; BX es mayor → AL = BL
    88                                      print_str msg_mayor
    22 00000078 B409                <1>  mov ah, 09h
    23 0000007A BA[6000]            <1>  mov dx, %1
    24 0000007D CD21                <1>  int 21h
    89 0000007F 88D8                        mov al, bl
    90                                      print_digito
